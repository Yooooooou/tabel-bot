# Скопируйте этот файл в .env и заполните значения

# Токен Telegram-бота (обязательно)
BOT_TOKEN=your_bot_token_here

# Telegram chat_id главного администратора (обязательно)
ADMIN_CHAT_ID=123456789

# ID Google Spreadsheet (обязательно)
SPREADSHEET_ID=your_spreadsheet_id_here

# Путь к файлу Google Service Account credentials
# При использовании docker-compose файл монтируется автоматически
GOOGLE_CREDS_JSON=credentials.json

# Публичный URL вашего сервиса для Telegram Webhook
# Например: https://tabel-bot-production.up.railway.app
WEBHOOK_URL=https://your-service.up.railway.app

# PostgreSQL (заполняется автоматически в docker-compose)
# На Railway: задайте DATABASE_URL из плагина PostgreSQL
# Если не задан — бот использует JSON-файл db.json (данные теряются при redeploy)
DATABASE_URL=postgresql://tabelbot:tabelbot@db:5432/tabelbot
